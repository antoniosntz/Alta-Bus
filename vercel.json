{
  "version": 2,
  "builds": [
    { "src": "servidor.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/login", "dest": "/servidor.js" },
    { "src": "/cadastrar", "dest": "/servidor.js" },
    { "src": "/localizacao", "dest": "/servidor.js" },
    { "src": "/tempo", "dest": "/servidor.js" },
    { "src": "/login.html", "dest": "/public/login.html" },
    { "src": "/cadastro.html", "dest": "/public/cadastro.html" },
    { "src": "/motorista.html", "dest": "/public/motorista.html" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}